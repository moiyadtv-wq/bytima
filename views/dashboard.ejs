<%- include('partials/header') %>
<style>
  .dash-card {
    transition: transform 0.2s, box-shadow 0.2s;
    cursor: pointer;
    border-radius: 16px;
    border: 1px solid rgba(124,45,255,0.1);
    overflow: hidden;
  }
  .dash-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(124,45,255,0.15);
  }
  .dash-card .card-body { padding: 2rem; }
  .dash-card .icon-circle {
    width: 64px; height: 64px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.8rem;
    margin-bottom: 1rem;
  }
  .dash-card h2 { font-weight: 700; margin-bottom: 0.25rem; }
  .dash-card .count-label { font-size: 0.9rem; opacity: 0.7; }
  .notification-badge {
    position: absolute; top: 12px; left: 12px;
    font-size: 0.75rem;
    min-width: 22px; height: 22px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 11px; font-weight: 700;
    box-shadow: 0 2px 8px rgba(220,53,69,0.3);
  }
</style>

<main class="d-flex flex-nowrap">
  <%- include('partials/sidebar', { currentPage: 'dashboard' }) %>
  <div class="b-example-divider b-example-vr"></div>

  <section class="flex-grow-1 p-4">
    <%- include('partials/navbar') %>

    <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success alert-dismissible fade show"><%= success %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger alert-dismissible fade show"><%= error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>

    <h4 class="mt-3 mb-4"><i class="bi bi-speedometer2 me-2"></i><%= __('dashboard') %></h4>

    <div class="row g-4">
      <div class="col-md-4">
        <a href="/admin/customers" class="text-decoration-none text-dark">
          <div class="card dash-card shadow-sm position-relative">
            <div class="card-body text-center">
              <div class="icon-circle bg-primary bg-opacity-10 text-primary mx-auto">
                <i class="bi bi-people-fill"></i>
              </div>
              <h2><%= customersCount %></h2>
              <p class="count-label"><%= __('customers') %></p>
              <small class="text-primary"><i class="bi bi-arrow-left"></i> <%= __('view_all') %></small>
            </div>
          </div>
        </a>
      </div>
      <div class="col-md-4">
        <a href="/products" class="text-decoration-none text-dark">
          <div class="card dash-card shadow-sm position-relative">
            <div class="card-body text-center">
              <div class="icon-circle bg-success bg-opacity-10 text-success mx-auto">
                <i class="bi bi-box-seam-fill"></i>
              </div>
              <h2><%= productsCount %></h2>
              <p class="count-label"><%= __('products') %></p>
              <small class="text-success"><i class="bi bi-arrow-left"></i> <%= __('view_all') %></small>
            </div>
          </div>
        </a>
      </div>
      <div class="col-md-4">
        <a href="/admin/orders" class="text-decoration-none text-dark">
          <div class="card dash-card shadow-sm position-relative">
            <% if (pendingOrders > 0) { %>
              <span class="notification-badge bg-danger text-white"><%= pendingOrders %></span>
            <% } %>
            <div class="card-body text-center">
              <div class="icon-circle bg-warning bg-opacity-10 text-warning mx-auto">
                <i class="bi bi-truck"></i>
              </div>
              <h2><%= ordersCount %></h2>
              <p class="count-label"><%= __('orders') %></p>
              <small class="text-warning"><i class="bi bi-arrow-left"></i> <%= __('view_all') %></small>
            </div>
          </div>
        </a>
      </div>
    </div>

    <div class="row g-4 mt-4">
      <div class="col-md-6">
        <div class="card shadow-sm">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h6 class="mb-0"><i class="bi bi-clock me-2 text-warning"></i><%= __('recent_orders') %></h6>
            <a href="/admin/orders" class="btn btn-sm btn-outline-primary"><%= __('view_all') %></a>
          </div>
          <div class="card-body p-0">
            <table class="table table-striped mb-0">
              <thead><tr><th><%= __('customer') %></th><th><%= __('total') %></th><th><%= __('status') %></th></tr></thead>
              <tbody>
                <% recentOrders.forEach(o => { %>
                  <tr>
                    <td><%= o.customerName %></td>
                    <td><%= __('currency') %><%= o.total.toFixed(2) %></td>
                    <td><span class="badge bg-<%= o.status === 'pending' ? 'warning' : o.status === 'delivered' ? 'success' : 'info' %>"><%= __(o.status) %></span></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card shadow-sm">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h6 class="mb-0"><i class="bi bi-box-seam me-2 text-success"></i><%= __('recent_products') %></h6>
            <a href="/products" class="btn btn-sm btn-outline-primary"><%= __('view_all') %></a>
          </div>
          <div class="card-body p-0">
            <table class="table table-striped mb-0">
              <thead><tr><th><%= __('name') %></th><th><%= __('price') %></th><th><%= __('category') %></th></tr></thead>
              <tbody>
                <% recentProducts.forEach(p => { %>
                  <tr><td><%= p.name %></td><td><%= __('currency') %><%= p.price %></td><td><%= p.category %></td></tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

<%- include('partials/scripts') %>
</body>
</html>
