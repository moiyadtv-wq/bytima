<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>" data-bs-theme="auto">
<head>
  <script src="/js/color-modes.js"></script>
  <link rel="stylesheet" href="/bootstrap-icons-1.10.5/font/bootstrap-icons.min.css" />
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= typeof title !== 'undefined' ? title : 'by tima' %></title>
  <link href="/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/css/dark-light.css" />
  <link href="/css/sidebars.css" rel="stylesheet" />
  <link rel="stylesheet" href="/css/myStyle.css" />
  <style>
    :root { --bs-primary: #7c2dff; --bs-primary-rgb: 124, 45, 255; }
    .btn-primary { --bs-btn-bg: #7c2dff; --bs-btn-border-color: #7c2dff; --bs-btn-hover-bg: #6a1fd6; --bs-btn-hover-border-color: #6a1fd6; --bs-btn-active-bg: #5a1ab5; }
    .btn-outline-primary { --bs-btn-color: #7c2dff; --bs-btn-border-color: #7c2dff; --bs-btn-hover-bg: #7c2dff; --bs-btn-hover-border-color: #7c2dff; --bs-btn-active-bg: #6a1fd6; }
    .text-primary { color: #7c2dff !important; }
    .bg-primary { background-color: #7c2dff !important; }
    .border-primary { border-color: #7c2dff !important; }
    .link-primary { color: #7c2dff !important; }
    .nav-pills .nav-link.active { background-color: #7c2dff !important; }
    .form-control:focus { border-color: #b366ff; box-shadow: 0 0 0 0.2rem rgba(124, 45, 255, 0.25); }
    .page-item.active .page-link { background-color: #7c2dff; border-color: #7c2dff; }
    .progress-bar { background-color: #7c2dff; }
    .dropdown-item:active { background-color: #7c2dff; }
    body { overflow-x: hidden; }
<% if (dir === 'rtl') { %>
    .sidebar { text-align: right; }
    .sidebar .nav-link i, .sidebar .nav-link svg { margin-left: 0.5rem; margin-right: 0; }
    .dropdown-menu.text-small { text-align: right; }
    .b-example-vr { border-left: none; border-right: 1px solid var(--bs-border-color); }
    .input-icon-wrap .icon { left: auto; right: 0.9rem; }
    .input-icon-wrap .form-control { padding-left: 1rem; padding-right: 2.5rem; }
    .position-absolute.top-0.start-100 { left: auto !important; right: 100% !important; }
    .me-2 { margin-right: 0 !important; margin-left: 0.5rem !important; }
    .ms-auto { margin-left: 0 !important; margin-right: auto !important; }
    .ms-2 { margin-left: 0 !important; margin-right: 0.5rem !important; }
    .me-auto { margin-right: 0 !important; margin-left: auto !important; }
    .text-end { text-align: left !important; }
    .text-start { text-align: right !important; }
    .dropdown-menu.text-start { text-align: right !important; }
    .input-group:not(.has-validation) > :not(:last-child):not(.dropdown-toggle):not(.dropdown-menu):not(.form-floating) { border-radius: 0 var(--bs-border-radius) var(--bs-border-radius) 0; }
    .input-group:not(.has-validation) > .dropdown-toggle:nth-last-child(n+3), .input-group:not(.has-validation) > .form-floating:not(:last-child) > .form-control, .input-group:not(.has-validation) > .form-floating:not(:last-child) > .form-select { border-radius: 0 var(--bs-border-radius) var(--bs-border-radius) 0; }
    .input-group > :first-child { border-radius: var(--bs-border-radius) 0 0 var(--bs-border-radius) !important; }
    <% } %>
  </style>
</head>
<body>
<div class="sidebar-backdrop" id="sidebarBackdrop" onclick="toggleMobileSidebar()"></div>
  <svg xmlns="http://www.w3.org/2000/svg" style="display: none">
