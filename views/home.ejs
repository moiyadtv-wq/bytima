<%- include('partials/header') %>
<style>
  .hero-section {
    background: linear-gradient(135deg, #1a0033 0%, #4a0080 30%, #7c2dff 60%, #b366ff 100%);
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: white;
    padding: 2rem;
    position: relative;
    overflow: hidden;
  }
  .hero-section::before {
    content: '<%= __('website_name') %>';
    position: absolute;
    font-size: clamp(10rem, 25vw, 25rem);
    font-weight: 900;
    color: rgba(255, 255, 255, 0.04);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    white-space: nowrap;
    user-select: none;
    letter-spacing: 0.1em;
  }
  .hero-content {
    position: relative;
    z-index: 1;
  }
  .hero-content h1 { font-size: 3.5rem; font-weight: 800; letter-spacing: -0.02em; }
  .hero-content .lead { font-size: 1.3rem; opacity: 0.9; }
  .glass-card {
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 24px;
    padding: 3rem 2.5rem;
    border: 1px solid rgba(255,255,255,0.15);
    box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
  }
  .hero-btn { border-radius: 50px; padding: 0.75rem 2rem; font-weight: 600; transition: all 0.3s; }
  .hero-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(0,0,0,0.2); }
  .feature-section { padding: 5rem 0; }
  .feature-card {
    border: none;
    border-radius: 20px;
    padding: 2.5rem 1.5rem;
    height: 100%;
    transition: transform 0.3s, box-shadow 0.3s;
    background: var(--bs-body-bg);
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
  }
  .feature-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 40px rgba(124,45,255,0.12);
  }
  .feature-icon-wrap {
    width: 70px;
    height: 70px;
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.25rem;
    font-size: 2rem;
    background: linear-gradient(135deg, #7c2dff22, #b366ff22);
    color: #7c2dff;
  }
  .floating-actions {
    position: fixed;
    bottom: 1.5rem;
    left: 1.5rem;
    z-index: 1500;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .floating-actions .btn {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
    transition: transform 0.2s;
  }
  .floating-actions .btn:hover { transform: scale(1.1); }
</style>

<main>
  <section class="hero-section">
    <div class="hero-content">
      <div class="glass-card">
        <div class="mb-3">
          <i class="bi bi-shop-window" style="font-size: 4rem; color: #b366ff;"></i>
        </div>
        <h1><%= __('website_name') %></h1>
        <p class="lead mb-3"><%= __('natural_beauty') %></p>
        <p class="mb-4"><%= __('hero_desc') %></p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
          <a href="/shop" class="btn btn-light hero-btn"><i class="bi bi-shop-window me-2"></i><%= __('start_shopping') %></a>
          <a href="/login" class="btn btn-outline-light hero-btn"><i class="bi bi-person me-2"></i><%= __('login_register') %></a>
          <a href="https://wa.me/<%= whatsappPhone %>" target="_blank" class="btn btn-outline-light hero-btn"><i class="bi bi-whatsapp me-2"></i>WhatsApp</a>
        </div>
      </div>
    </div>
  </section>

  <section class="feature-section container">
    <div class="row g-4">
      <div class="col-md-4">
        <div class="feature-card text-center">
          <div class="feature-icon-wrap"><i class="bi bi-truck"></i></div>
          <h5><%= __('free_shipping') %></h5>
          <p class="text-muted mb-0"><%= __('free_shipping_desc') %></p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feature-card text-center">
          <div class="feature-icon-wrap"><i class="bi bi-shield-check"></i></div>
          <h5><%= __('natural_products') %></h5>
          <p class="text-muted mb-0"><%= __('natural_products_desc') %></p>
        </div>
      </div>
      <div class="col-md-4">
        <a href="https://wa.me/<%= whatsappPhone %>" target="_blank" class="text-decoration-none">
          <div class="feature-card text-center">
            <div class="feature-icon-wrap" style="color: #25D366;"><i class="bi bi-whatsapp"></i></div>
            <h5><%= __('whatsapp_support') %></h5>
            <p class="text-muted mb-0"><%= __('whatsapp_support_desc') %></p>
            <small class="text-success mt-2 d-block"><i class="bi bi-whatsapp"></i> <%= whatsappPhone %></small>
          </div>
        </a>
      </div>
    </div>
  </section>

  <footer class="text-center py-4 text-muted small border-top">
    <div class="mb-2">
      <a href="mailto:tymatyma228@gmail.com" class="text-muted text-decoration-none me-3"><i class="bi bi-envelope"></i> tymatyma228@gmail.com</a>
      <a href="https://www.facebook.com/share/18RT76SnLr/" target="_blank" class="text-muted text-decoration-none me-3"><i class="bi bi-facebook"></i> Facebook</a>
      <a href="https://www.instagram.com/by.tima24?igsh=MXQxY3UwaTllZ2FvNg==" target="_blank" class="text-muted text-decoration-none"><i class="bi bi-instagram"></i> Instagram</a>
    </div>
    <div><%= __('website_name') %> &copy; 2026</div>
  </footer>
</main>

<div class="floating-actions">
  <button class="btn btn-dark" onclick="toggleTheme()" title="Toggle theme"><i class="bi bi-moon-stars-fill"></i></button>
  <div class="dropdown dropup">
    <button class="btn btn-dark" data-bs-toggle="dropdown"><i class="bi bi-globe"></i></button>
    <ul class="dropdown-menu mb-2">
      <li><a class="dropdown-item <%= lang === 'ar' ? 'active' : '' %>" href="?lang=ar">العربية</a></li>
      <li><a class="dropdown-item <%= lang === 'en' ? 'active' : '' %>" href="?lang=en">English</a></li>
    </ul>
  </div>
</div>

<%- include('partials/scripts') %>
</body>
</html>