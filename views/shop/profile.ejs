<%- include('../partials/header') %>
<main class="d-flex flex-nowrap">
  <%- include('../partials/sidebar', { currentPage: 'profile' }) %>
  <div class="b-example-divider b-example-vr"></div>

  <section class="flex-grow-1 p-4">
    <%- include('../partials/navbar') %>

    <h4 class="mt-3 mb-3"><i class="bi bi-person-circle me-2"></i><%= __('profile') %></h4>

    <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success alert-dismissible fade show"><%= success %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger alert-dismissible fade show"><%= __(error) %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>

    <div class="card shadow-sm">
      <div class="card-body">
        <form action="/shop/profile" method="POST" enctype="multipart/form-data" class="row g-3">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <!-- Profile Image -->
          <div class="col-12 text-center mb-3">
            <img src="<%= customer.image || '/img/no-image.svg' %>" class="rounded-circle border" style="width:120px;height:120px;object-fit:cover" id="profilePreview">
            <div class="mt-2">
              <label class="btn btn-sm btn-outline-primary"><i class="bi bi-camera"></i> <%= __('choose_image') %>
                <input type="file" name="image" accept="image/*" class="d-none" id="profileImageInput">
              </label>
              <small class="text-muted d-block"><%= __('optional') %></small>
            </div>
          </div>

          <!-- First Name & Last Name -->
          <div class="col-md-6">
            <label class="form-label"><%= __('first_name') %> <span class="text-danger">*</span></label>
            <input type="text" class="form-control" name="firstName" value="<%= customer.firstName || '' %>" required>
          </div>
          <div class="col-md-6">
            <label class="form-label"><%= __('last_name') %> <span class="text-danger">*</span></label>
            <input type="text" class="form-control" name="lastName" value="<%= customer.lastName || '' %>" required>
          </div>

          <!-- Phone & Email -->
          <div class="col-md-6">
            <label class="form-label"><%= __('phone_number') %> <span class="text-danger">*</span></label>
            <input type="tel" class="form-control" name="phone" value="<%= customer.phone %>" required>
          </div>
          <div class="col-md-6">
            <label class="form-label"><%= __('email') %></label>
            <input type="email" class="form-control" name="email" value="<%= customer.email || '' %>">
          </div>

          <!-- Country -->
          <div class="col-md-4">
            <label class="form-label"><%= __('country') %> <span class="text-danger">*</span></label>
            <select class="form-control" name="country" required>
              <option value="" disabled selected><%= __('country') %></option>
              <option value="Syria" <%= customer.country === 'Syria' ? 'selected' : '' %>>سوريا</option>
              <option value="Lebanon" <%= customer.country === 'Lebanon' ? 'selected' : '' %>>لبنان</option>
              <option value="Jordan" <%= customer.country === 'Jordan' ? 'selected' : '' %>>الأردن</option>
              <option value="Iraq" <%= customer.country === 'Iraq' ? 'selected' : '' %>>العراق</option>
              <option value="Egypt" <%= customer.country === 'Egypt' ? 'selected' : '' %>>مصر</option>
              <option value="Saudi Arabia" <%= customer.country === 'Saudi Arabia' ? 'selected' : '' %>>السعودية</option>
              <option value="UAE" <%= customer.country === 'UAE' ? 'selected' : '' %>>الإمارات</option>
              <option value="Kuwait" <%= customer.country === 'Kuwait' ? 'selected' : '' %>>الكويت</option>
              <option value="Qatar" <%= customer.country === 'Qatar' ? 'selected' : '' %>>قطر</option>
              <option value="Bahrain" <%= customer.country === 'Bahrain' ? 'selected' : '' %>>البحرين</option>
              <option value="Oman" <%= customer.country === 'Oman' ? 'selected' : '' %>>عُمان</option>
              <option value="Turkey" <%= customer.country === 'Turkey' ? 'selected' : '' %>>تركيا</option>
              <option value="Other" <%= customer.country === 'Other' ? 'selected' : '' %>>أخرى</option>
            </select>
          </div>

          <!-- Governorate -->
          <div class="col-md-4">
            <label class="form-label"><%= __('governorate') %> <span class="text-danger">*</span></label>
            <input type="text" class="form-control" name="governorate" value="<%= customer.governorate || '' %>" required>
          </div>

          <!-- Region -->
          <div class="col-md-4">
            <label class="form-label"><%= __('region') %> <span class="text-danger">*</span></label>
            <input type="text" class="form-control" name="region" value="<%= customer.region || '' %>" required>
          </div>

          <!-- Detailed Address -->
          <div class="col-12">
            <label class="form-label"><%= __('detailed_address') %> <span class="text-danger">*</span></label>
            <textarea class="form-control" name="detailedAddress" rows="2" required><%= customer.detailedAddress || '' %></textarea>
          </div>

          <div class="col-12">
            <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> <%= __('save') %></button>
          </div>
        </form>
      </div>
    </div>
  </section>
</main>

<%- include('../partials/scripts') %>
<script nonce="<%= nonce %>">
  document.getElementById('profileImageInput').addEventListener('change', function() {
    document.getElementById('profilePreview').src = URL.createObjectURL(this.files[0]);
  });
</script>
</body>
</html>
