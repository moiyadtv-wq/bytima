<%- include('../partials/header') %>
<main class="d-flex flex-nowrap">
  <%- include('../partials/sidebar', { currentPage: 'settings' }) %>
  <div class="b-example-divider b-example-vr"></div>

  <section class="flex-grow-1 p-4">
    <%- include('../partials/navbar') %>

    <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success alert-dismissible fade show"><%= success %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger alert-dismissible fade show"><%= __(error) %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>

    <h4 class="mt-3 mb-4"><i class="bi bi-gear me-2"></i><%= __('settings') %></h4>

    <!-- Language & Theme -->
    <div class="card shadow-sm mb-3">
      <div class="card-body">
        <h5 class="card-title"><i class="bi bi-palette me-2"></i><%= __('appearance') %></h5>
        <div class="d-flex gap-2 mt-3">
          <button class="btn btn-outline-primary flex-fill" onclick="toggleLang()"><i class="bi bi-globe me-1"></i> <%= __('language') %>: <%= lang === 'ar' ? 'العربية' : 'English' %></button>
          <button class="btn btn-outline-primary flex-fill" onclick="toggleTheme()"><i class="bi bi-moon-stars-fill me-1"></i> <%= __('theme') %></button>
        </div>
      </div>
    </div>

    <% if (customer) { %>
    <!-- Security & Account -->
    <div class="card shadow-sm mb-3">
      <div class="card-body">
        <h5 class="card-title"><i class="bi bi-shield-lock me-2"></i><%= __('security') %></h5>
        <div class="list-group list-group-flush mt-3">
          <a href="/shop/profile" class="list-group-item list-group-item-action d-flex align-items-center">
            <i class="bi bi-person fs-5 me-3"></i>
            <div>
              <strong><%= __('personal_info') %></strong>
              <small class="d-block text-muted"><%= __('full_name') %>, <%= __('email') %>, <%= __('phone') %>, <%= __('address') %></small>
            </div>
            <i class="bi bi-chevron-right ms-auto"></i>
          </a>
          <a href="/shop/change-password" class="list-group-item list-group-item-action d-flex align-items-center">
            <i class="bi bi-lock fs-5 me-3"></i>
            <div>
              <strong><%= __('change_password') %></strong>
              <small class="d-block text-muted"><%= __('update_account_password') %></small>
            </div>
            <i class="bi bi-chevron-right ms-auto"></i>
          </a>
        </div>
      </div>
    </div>
    <% } %>

    <!-- Payment Methods -->
    <div class="card shadow-sm mb-3">
      <div class="card-body">
        <h5 class="card-title"><i class="bi bi-credit-card me-2"></i><%= __('payment_methods') %></h5>
        <div class="list-group list-group-flush mt-3">
          <div class="list-group-item d-flex align-items-center">
            <i class="bi bi-cash fs-5 me-3"></i>
            <div>
              <strong><%= __('cash_on_delivery') %></strong>
              <small class="d-block text-muted"><%= __('pay_when_receive') %></small>
            </div>
          </div>
          <% if (shamCashName || shamCashPhone) { %>
          <div class="list-group-item d-flex align-items-center">
            <i class="bi bi-building fs-5 me-3"></i>
            <div>
              <strong><%= __('sham_cash') %></strong>
              <small class="d-block text-muted">
                <% if (shamCashName) { %><%= __('account_name') %>: <%= shamCashName %><br><% } %>
                <% if (shamCashPhone) { %><%= __('phone') %>: <%= shamCashPhone %><% } %>
              </small>
            </div>
          </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Contact via WhatsApp -->
    <% if (whatsappPhone) { %>
    <div class="card shadow-sm mb-3">
      <div class="card-body">
        <h5 class="card-title"><i class="bi bi-whatsapp me-2"></i><%= __('contact_us') %></h5>
        <p class="text-muted mb-2"><%= __('contact_whatsapp_msg') %></p>
        <a href="https://wa.me/<%= whatsappPhone %>" target="_blank" class="btn btn-success w-100">
          <i class="bi bi-whatsapp me-2"></i><%= __('chat_whatsapp') %>
        </a>
      </div>
    </div>
    <% } %>
  </section>
</main>

<%- include('../partials/scripts') %>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    setTimeout(function() {
      document.querySelectorAll('.alert-dismissible').forEach(el => {
        const bs = new bootstrap.Alert(el);
        setTimeout(() => bs.close(), 4000);
      });
    }, 100);
  });
</script>
</body>
</html>
