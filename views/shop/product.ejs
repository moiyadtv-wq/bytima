<%- include('../partials/header') %>
<main class="d-flex flex-nowrap">
  <%- include('../partials/sidebar', { currentPage: 'shop' }) %>
  <div class="b-example-divider b-example-vr"></div>

  <section class="w-100 p-4">
    <%- include('../partials/navbar') %>

    <nav aria-label="breadcrumb" class="mt-2">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/shop"><%= __('shop') %></a></li>
        <li class="breadcrumb-item active"><%= product.name %></li>
      </ol>
    </nav>

    <div class="row g-4 mt-2">
      <div class="col-md-5">
        <img src="<%= product.image || '/img/no-image.svg' %>" class="img-fluid rounded shadow main-image" alt="<%= product.name %>" style="cursor:pointer" data-bs-toggle="modal" data-bs-target="#imageModal">
        <% if (product.images && product.images.length > 0) { %>
          <div class="d-flex gap-2 mt-2 flex-wrap">
            <% product.images.forEach(img => { %>
              <img src="<%= img.url || img %>" class="img-thumbnail" style="width: 70px; height: 70px; object-fit: cover; cursor: pointer;" onclick="document.querySelector('.main-image').src=this.src">
            <% }) %>
          </div>
        <% } %>
      </div>
      <div class="col-md-7">
        <h2><%= product.name %></h2>
        <h4 class="text-primary"><%= __('currency') %><%= product.price %>
          <% if (product.oldPrice > product.price) { %>
            <small class="text-muted text-decoration-line-through"><%= __('currency') %><%= product.oldPrice %></small>
          <% } %>
        </h4>
        <% if (!product.inStock) { %>
          <span class="badge bg-danger"><%= __('out_of_stock') %></span>
        <% } else { %>
          <span class="badge bg-success"><%= __('in_stock') %></span>
        <% } %>

        <hr>
        <p><%= product.description %></p>

        <% if (product.ingredients) { %>
          <h6><%= __('ingredients') %></h6>
          <p class="text-muted"><%= product.ingredients %></p>
        <% } %>

        <% if (product.usage) { %>
          <h6><%= __('how_to_use') %></h6>
          <p class="text-muted"><%= product.usage %></p>
        <% } %>

        <% if (product.weight) { %>
          <p><small class="text-muted"><%= __('weight') %>: <%= product.weight %></small></p>
        <% } %>

        <div class="d-flex gap-2 mt-3">
          <button class="btn btn-primary btn-lg add-to-cart" data-id="<%= product._id %>">
            <i class="bi bi-cart-plus"></i> <%= __('add_to_cart') %>
          </button>
          <a href="/shop/buy-now/<%= product._id %>" class="btn btn-success btn-lg">
            <i class="bi bi-truck"></i> <%= __('buy_now') %>
          </a>
        </div>
      </div>
    </div>

    <% if (related.length > 0) { %>
      <h5 class="mt-5 mb-3"><%= __('related_products') %></h5>
      <div class="row g-3">
        <% related.forEach(p => { %>
          <div class="col-6 col-md-3">
            <div class="card shadow-sm h-100">
              <a href="/shop/product/<%= p._id %>">
                <img src="<%= p.image || '/img/no-image.svg' %>" class="card-img-top" alt="<%= p.name %>" style="height: 150px; object-fit: cover;">
              </a>
              <div class="card-body">
                <h6 class="card-title"><a href="/shop/product/<%= p._id %>" class="text-decoration-none text-dark"><%= p.name %></a></h6>
                <p class="mb-0"><strong><%= __('currency') %><%= p.price %></strong></p>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </section>
</main>

<%- include('../partials/scripts') %>

<!-- Image Lightbox Modal -->
<div class="modal fade" id="imageModal" tabindex="-1">
  <div class="modal-dialog modal-fullscreen">
    <div class="modal-content bg-black">
      <div class="modal-header border-0">
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body d-flex align-items-center justify-content-center p-0">
        <img src="" class="img-fluid" id="lightboxImage" alt="">
      </div>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll('.main-image').forEach(img => {
    img.addEventListener('click', function() {
      document.getElementById('lightboxImage').src = this.src;
    });
  });
  document.querySelectorAll('.add-to-cart').forEach(btn => {
    btn.addEventListener('click', async function() {
      const id = this.dataset.id;
      const res = await fetch('/shop/cart/add/' + id, { method: 'POST' });
      const data = await res.json();
      if (data.success) showToast('<%= __('added_to_cart') %>', 'success');
    });
  });
</script>
</body>
</html>
