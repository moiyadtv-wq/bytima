<%- include('../partials/header') %>
<main class="d-flex flex-nowrap">
  <%- include('../partials/sidebar', { currentPage: 'shop' }) %>
  <div class="b-example-divider b-example-vr"></div>

  <section class="w-100 p-4">
    <%- include('../partials/navbar') %>

    <div class="text-center py-5">
      <i class="bi bi-check-circle text-success" style="font-size: 4rem;"></i>
      <h3 class="mt-3"><%= __('order_placed') %></h3>
      <p class="text-muted"><%= __('order_id') %>: <%= order._id %></p>
    </div>

    <div class="card shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between mb-3">
          <h5 class="mb-0"><%= __('order_details') %></h5>
          <div>
            <% if (order.isReturning) { %>
              <span class="badge bg-success"><%= __('returning_customer') %></span>
            <% } else { %>
              <span class="badge bg-info"><%= __('new_customer') %></span>
            <% } %>
            <% if (order.paymentMethod === 'cash') { %>
              <span class="badge bg-secondary"><%= __('cash_on_delivery') %></span>
            <% } else { %>
              <span class="badge bg-info"><%= __('sham_cash') %></span>
            <% } %>
          </div>
        </div>
        <table class="table table-sm">
          <thead><tr><th><%= __('product') %></th><th><%= __('quantity') %></th><th><%= __('price') %></th></tr></thead>
          <tbody>
            <% order.items.forEach(item => { %>
              <tr><td><%= item.name %></td><td><%= item.quantity %></td><td><%= __('currency') %><%= (item.price * item.quantity).toFixed(2) %></td></tr>
            <% }) %>
          </tbody>
        </table>
        <hr>
        <h5 class="d-flex justify-content-between">
          <span><%= __('total') %>:</span>
          <strong><%= __('currency') %><%= order.total.toFixed(2) %></strong>
        </h5>
        <p class="text-muted small">
          <%= __('payment_method') %>: <strong><%= order.paymentMethod === 'cash' ? __('cash_on_delivery') : __('sham_cash') %></strong> &middot;
          <%= __('status') %>: <span class="badge bg-<%= order.status === 'pending' ? 'warning' : order.status === 'confirmed' ? 'info' : order.status === 'processing' ? 'secondary' : order.status === 'shipped' ? 'primary' : order.status === 'delivered' ? 'success' : 'danger' %>"><%= __(order.status) %></span>
        </p>
      </div>
    </div>

    <% if (order.statusHistory && order.statusHistory.length > 0) { %>
    <div class="card shadow-sm mt-3">
      <div class="card-body">
        <h5 class="mb-3"><i class="bi bi-clock-history me-2"></i><%= __('order_status_history') %></h5>
        <ul class="list-unstyled mb-0">
          <% order.statusHistory.forEach(h => { %>
          <li class="d-flex align-items-start mb-2">
            <i class="bi bi-check-circle-fill text-success me-2 mt-1"></i>
            <div>
              <strong><%= __(h.status) %></strong>
              <% if (h.note) { %><br><small class="text-muted"><%= h.note %></small><% } %>
              <br><small class="text-muted"><%= new Date(h.changedAt).toLocaleDateString() %> <%= new Date(h.changedAt).toLocaleTimeString() %></small>
            </div>
          </li>
          <% }) %>
        </ul>
      </div>
    </div>
    <% } %>

    <div class="text-center mt-4">
      <a href="/shop/my-orders" class="btn btn-outline-primary"><i class="bi bi-arrow-left"></i> <%= __('back_to_orders') %></a>
      <a href="/shop" class="btn btn-primary"><i class="bi bi-shop-window"></i> <%= __('continue_shopping') %></a>
    </div>
  </section>
</main>

<%- include('../partials/scripts') %>
</body>
</html>
