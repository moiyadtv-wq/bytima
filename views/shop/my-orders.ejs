<%- include('../partials/header') %>
<main class="d-flex flex-nowrap">
  <%- include('../partials/sidebar', { currentPage: 'my-orders' }) %>
  <div class="b-example-divider b-example-vr"></div>

  <section class="flex-grow-1 p-4">
    <%- include('../partials/navbar') %>

    <h4 class="mt-3 mb-3"><i class="bi bi-box me-2"></i><%= __('my_orders') %></h4>

    <% if (!customer) { %>
    <div class="card shadow-sm mb-4">
      <div class="card-body">
        <form class="row g-2" method="GET">
          <div class="col-md-6">
            <input type="tel" class="form-control" name="phone" placeholder="<%= __('enter_phone') %>" value="<%= searchPhone %>" required>
          </div>
          <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100"><i class="bi bi-search"></i> <%= __('search') %></button>
          </div>
        </form>
      </div>
    </div>
    <% } %>

    <% if (searchPhone && orders.length === 0) { %>
      <div class="text-center py-5 text-muted">
        <i class="bi bi-inbox" style="font-size: 3rem;"></i>
        <h5 class="mt-2"><%= __('no_orders') %></h5>
      </div>
    <% } %>

    <% if (orders.length > 0) { %>
      <% orders.forEach(order => { %>
        <a href="/shop/orders/<%= order._id %>" class="text-decoration-none">
          <div class="card shadow-sm mb-2">
            <div class="card-body d-flex justify-content-between align-items-center">
              <div>
                <strong><%= __('order') %> #<%= order._id.toString().slice(-6) %></strong>
                <div class="text-muted small"><%= new Date(order.createdAt).toLocaleDateString() %></div>
                <div class="text-muted small"><%= order.items.map(i => i.name + ' x' + i.quantity).join(', ') %></div>
              </div>
              <div class="text-end">
                <div><strong><%= __('currency') %><%= order.total.toFixed(2) %></strong></div>
                <span class="badge bg-<%= order.status === 'pending' ? 'warning' : order.status === 'confirmed' ? 'info' : order.status === 'shipped' ? 'primary' : order.status === 'delivered' ? 'success' : 'danger' %>">
                  <%= __(order.status) %>
                </span>
              </div>
            </div>
          </div>
        </a>
      <% }) %>
    <% } %>

    <div class="text-center mt-3">
      <a href="/shop" class="btn btn-outline-primary"><i class="bi bi-shop-window"></i> <%= __('continue_shopping') %></a>
    </div>
  </section>
</main>

<%- include('../partials/scripts') %>
</body>
</html>
