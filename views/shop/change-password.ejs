<%- include('../partials/header') %>
<main class="d-flex flex-nowrap">
  <%- include('../partials/sidebar', { currentPage: 'profile' }) %>
  <div class="b-example-divider b-example-vr"></div>

  <section class="flex-grow-1 p-4">
    <%- include('../partials/navbar') %>

    <h4 class="mt-3 mb-3"><i class="bi bi-lock me-2"></i><%= __('change_password') %></h4>

    <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success alert-dismissible fade show"><%= success %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger alert-dismissible fade show"><%= __(error) %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>

    <div class="card shadow-sm">
      <div class="card-body">
        <form action="/shop/change-password" method="POST" class="row g-3">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <div class="col-12">
            <label class="form-label"><%= __('current_password') %></label>
            <input type="password" class="form-control" name="currentPassword" required>
          </div>
          <div class="col-md-6">
            <label class="form-label"><%= __('new_password') %></label>
            <input type="password" class="form-control" name="newPassword" required minlength="6">
          </div>
          <div class="col-md-6">
            <label class="form-label"><%= __('confirm_password') %></label>
            <input type="password" class="form-control" name="confirmPassword" required minlength="6">
          </div>
          <div class="col-12">
            <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> <%= __('save') %></button>
            <a href="/shop/profile" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> <%= __('back') %></a>
          </div>
        </form>
      </div>
    </div>
  </section>
</main>

<%- include('../partials/scripts') %>
</body>
</html>
