<%- include('../partials/header') %>
<main class="d-flex flex-nowrap">
  <%- include('../partials/sidebar', { currentPage: 'users' }) %>
  <div class="b-example-divider b-example-vr"></div>

  <section class="flex-grow-1 p-4">
    <%- include('../partials/navbar') %>

    <div class="card shadow mt-4">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><%= __('user_management') %></h5>
        <a href="/export/people" class="btn btn-sm btn-outline-primary"><i class="bi bi-download"></i> <%= __('export_customers') %></a>
      </div>
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead><tr><th><%= __('email') %></th><th><%= __('role') %></th><th><%= __('created') %></th><th><%= __('action') %></th></tr></thead>
          <tbody>
            <% users.forEach(u => { %>
              <tr>
                <td><%= u.email %></td>
                <td><span class="badge <%= u.role === 'admin' ? 'bg-danger' : 'bg-secondary' %>"><%= u.role %></span></td>
                <td><%= u.createdAt ? new Date(u.createdAt).toLocaleDateString() : '-' %></td>
                <td>
                  <form action="/admin/users/<%= u._id %>/toggle-role" method="POST" style="display:inline">
                    <button class="btn btn-sm btn-warning"><%= __('toggle_admin') %></button>
                  </form>
                  <button class="btn btn-sm btn-danger" onclick="showConfirm('<%= __('confirm_delete_msg') %>', function() { document.getElementById('deleteUser<%= u._id %>').submit(); })"><%= __('delete') %></button>
                  <form id="deleteUser<%= u._id %>" action="/admin/users/<%= u._id %>/delete" method="POST" style="display:none"></form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </section>
</main>

<%- include('../partials/scripts') %>
</body>
</html>
