<%- include('../partials/header') %>
<main class="d-flex flex-nowrap">
  <%- include('../partials/sidebar', { currentPage: 'settings' }) %>
  <div class="b-example-divider b-example-vr"></div>

  <section class="flex-grow-1 p-4">
    <%- include('../partials/navbar') %>

    <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success alert-dismissible fade show"><%= success %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger alert-dismissible fade show"><%= __(error) %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>

    <h4 class="mt-3 mb-4"><i class="bi bi-gear me-2"></i><%= __('settings') %></h4>

    <!-- Appearance -->
    <div class="card shadow-sm mb-3">
      <div class="card-body">
        <h5 class="card-title"><i class="bi bi-palette me-2"></i><%= __('appearance') %></h5>
        <div class="d-flex gap-2 mt-3">
          <button class="btn btn-outline-primary flex-fill" onclick="toggleLang()"><i class="bi bi-globe me-1"></i> <%= __('language') %>: <%= lang === 'ar' ? 'العربية' : 'English' %></button>
          <button class="btn btn-outline-primary flex-fill" onclick="toggleTheme()"><i class="bi bi-moon-stars-fill me-1"></i> <%= __('theme') %></button>
        </div>
      </div>
    </div>

    <!-- Security / Account -->
    <div class="card shadow-sm mb-3">
      <div class="card-body">
        <h5 class="card-title"><i class="bi bi-shield-lock me-2"></i><%= __('security') %></h5>
        <div class="list-group list-group-flush mt-3">
          <div class="list-group-item d-flex align-items-center">
            <i class="bi bi-person fs-5 me-3"></i>
            <div>
              <strong><%= __('email') %>:</strong> <%= user.email %>
              <% if (user.name) { %><br><small class="text-muted"><%= __('name') %>: <%= user.name %></small><% } %>
            </div>
          </div>
          <a href="/admin/change-password" class="list-group-item list-group-item-action d-flex align-items-center">
            <i class="bi bi-lock fs-5 me-3"></i>
            <div>
              <strong><%= __('change_password') %></strong>
              <small class="d-block text-muted"><%= __('update_account_password') %></small>
            </div>
            <i class="bi bi-chevron-right ms-auto"></i>
          </a>
        </div>
      </div>
    </div>

    <!-- Payment Methods -->
    <div class="card shadow-sm mb-3">
      <div class="card-body">
        <h5 class="card-title"><i class="bi bi-credit-card me-2"></i><%= __('payment_methods') %></h5>
        <form action="/admin/settings" method="POST" class="row g-3 mt-1">
          <div class="col-md-6">
            <label class="form-label"><%= __('sham_cash_name') %></label>
            <input type="text" class="form-control" name="shamCashName" value="<%= shamCashName || '' %>">
          </div>
          <div class="col-md-6">
            <label class="form-label"><%= __('sham_cash_phone') %></label>
            <input type="text" class="form-control" name="shamCashPhone" value="<%= shamCashPhone || '' %>" dir="ltr">
          </div>
          <div class="col-12">
            <h6 class="text-primary mt-2"><i class="bi bi-whatsapp"></i> <%= __('whatsapp_settings') %></h6>
          </div>
          <div class="col-md-6">
            <label class="form-label"><%= __('whatsapp_phone') %></label>
            <input type="text" class="form-control" name="whatsappPhone" value="<%= whatsappPhone || '' %>" dir="ltr">
            <small class="text-muted"><%= __('whatsapp_phone_desc') %></small>
          </div>
          <div class="col-12">
            <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> <%= __('save') %></button>
          </div>
        </form>
      </div>
    </div>

    <!-- Quick Links -->
    <div class="card shadow-sm mb-3">
      <div class="card-body">
        <h5 class="card-title"><i class="bi bi-link-45deg me-2"></i><%= __('quick_links') %></h5>
        <div class="list-group list-group-flush mt-3">
          <a href="/admin/users" class="list-group-item list-group-item-action d-flex align-items-center">
            <i class="bi bi-shield-lock fs-5 me-3"></i>
            <div>
              <strong><%= __('user_management') %></strong>
              <small class="d-block text-muted"><%= __('manage_employees') %></small>
            </div>
            <i class="bi bi-chevron-right ms-auto"></i>
          </a>
          <a href="/admin/activity" class="list-group-item list-group-item-action d-flex align-items-center">
            <i class="bi bi-activity fs-5 me-3"></i>
            <div>
              <strong><%= __('activity_log') %></strong>
              <small class="d-block text-muted"><%= __('view_admin_activity') %></small>
            </div>
            <i class="bi bi-chevron-right ms-auto"></i>
          </a>
        </div>
      </div>
    </div>
  </section>
</main>

<%- include('../partials/scripts') %>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    setTimeout(function() {
      document.querySelectorAll('.alert-dismissible').forEach(el => {
        const bs = new bootstrap.Alert(el);
        setTimeout(() => bs.close(), 4000);
      });
    }, 100);
  });
</script>
</body>
</html>
