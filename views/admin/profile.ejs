<%- include('../partials/header') %>
<main class="d-flex flex-nowrap">
  <%- include('../partials/sidebar', { currentPage: 'profile' }) %>
  <div class="b-example-divider b-example-vr"></div>

  <section class="flex-grow-1 p-4">
    <%- include('../partials/navbar') %>

    <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success alert-dismissible fade show"><%= success %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger alert-dismissible fade show"><%= __(error) %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>

    <h4 class="mt-3 mb-3"><i class="bi bi-person-circle me-2"></i><%= __('profile') %></h4>

    <div class="card shadow-sm">
      <div class="card-body">
        <form action="/admin/profile" method="POST" enctype="multipart/form-data" class="row g-3">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <div class="col-12 text-center mb-3">
            <img src="<%= user.image || '/img/no-image.svg' %>" class="rounded-circle border" style="width:120px;height:120px;object-fit:cover" id="profilePreview">
            <div class="mt-2">
              <label class="btn btn-sm btn-outline-primary"><i class="bi bi-camera"></i> <%= __('choose_image') %>
                <input type="file" name="image" accept="image/*" class="d-none" id="profileImageInput">
              </label>
              <small class="text-muted d-block"><%= __('optional') %></small>
            </div>
          </div>

          <div class="col-md-6">
            <label class="form-label"><%= __('name') %></label>
            <input type="text" class="form-control" name="name" value="<%= user.name || '' %>">
          </div>
          <div class="col-md-6">
            <label class="form-label"><%= __('email') %></label>
            <input type="email" class="form-control" value="<%= user.email %>" disabled>
          </div>
          <div class="col-md-6">
            <label class="form-label"><%= __('phone') %></label>
            <input type="tel" class="form-control" name="phone" value="<%= user.phone || '' %>">
          </div>
          <div class="col-md-6">
            <label class="form-label"><%= __('role') %></label>
            <input type="text" class="form-control" value="<%= user.role === 'admin' ? __('role_admin') : __('role_employee') %>" disabled>
          </div>

          <div class="col-12">
            <hr>
            <h6><%= __('change_password') %></h6>
            <small class="text-muted"><%= __('leave_empty') %></small>
          </div>
          <div class="col-md-4">
            <label class="form-label"><%= __('current_password') %></label>
            <input type="password" class="form-control" name="currentPassword">
          </div>
          <div class="col-md-4">
            <label class="form-label"><%= __('new_password') %></label>
            <input type="password" class="form-control" name="newPassword">
          </div>
          <div class="col-md-4">
            <label class="form-label"><%= __('confirm_password') %></label>
            <input type="password" class="form-control" name="confirmPassword">
          </div>

          <div class="col-12">
            <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> <%= __('save') %></button>
          </div>
        </form>
      </div>
    </div>
  </section>
</main>

<%- include('../partials/scripts') %>
<script nonce="<%= nonce %>">
  document.getElementById('profileImageInput').addEventListener('change', function() {
    document.getElementById('profilePreview').src = URL.createObjectURL(this.files[0]);
  });
</script>
</body>
</html>
