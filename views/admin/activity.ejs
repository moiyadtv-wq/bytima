<%- include('../partials/header') %>
<main class="d-flex flex-nowrap">
  <%- include('../partials/sidebar', { currentPage: 'activity' }) %>
  <div class="b-example-divider b-example-vr"></div>

  <section class="w-100 p-4">
    <%- include('../partials/navbar') %>

    <div class="card shadow mt-4">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-activity me-2"></i><%= __('activity_log') %></h5>
        <span class="badge bg-primary"><%= total %> <%= __('total') %></span>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-striped table-hover mb-0 align-middle">
            <thead><tr>
              <th><%= __('date') %></th>
              <th><%= __('user') %></th>
              <th><%= __('action') %></th>
              <th><%= __('details') %></th>
            </tr></thead>
            <tbody>
              <% if (logs.length === 0) { %>
                <tr><td colspan="4" class="text-center py-4 text-muted"><%= __('no_activity_yet') %></td></tr>
              <% } else { %>
                <% logs.forEach(log => { %>
                  <tr>
                    <td><small><%= new Date(log.createdAt).toLocaleString() %></small></td>
                    <td><%= log.userEmail %></td>
                    <td><span class="badge bg-secondary"><%= __(log.action) %></span></td>
                    <td><small class="text-muted"><%= log.details %></small></td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <% if (pages > 1) { %>
    <nav class="mt-3">
      <ul class="pagination justify-content-center">
        <% for (let i = 1; i <= pages; i++) { %>
          <li class="page-item <%= i === page ? 'active' : '' %>">
            <a class="page-link" href="/admin/activity?page=<%= i %>"><%= i %></a>
          </li>
        <% } %>
      </ul>
    </nav>
    <% } %>
  </section>
</main>

<%- include('../partials/scripts') %>
</body>
</html>