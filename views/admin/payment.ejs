<%- include('../partials/header') %>
<main class="d-flex flex-nowrap">
  <%- include('../partials/sidebar', { currentPage: 'payment' }) %>
  <div class="b-example-divider b-example-vr"></div>

  <section class="flex-grow-1 p-4">
    <%- include('../partials/navbar') %>

    <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success alert-dismissible fade show"><%= __(success) %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger alert-dismissible fade show"><%= __(error) %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>

    <div class="card shadow mt-4">
      <div class="card-header"><h5 class="mb-0"><i class="bi bi-credit-card me-2"></i><%= __('payment_settings') %></h5></div>
      <div class="card-body">
        <form action="/admin/payment-settings" method="POST" class="row g-3">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <div class="col-12">
            <h6 class="text-primary"><i class="bi bi-phone"></i> <%= __('sham_cash') %></h6>
          </div>
          <div class="col-md-6">
            <label class="form-label"><%= __('sham_cash_name') %></label>
            <input type="text" class="form-control" name="shamCashName" value="<%= shamCashName || '' %>">
          </div>
          <div class="col-md-6">
            <label class="form-label"><%= __('sham_cash_phone') %></label>
            <input type="text" class="form-control" name="shamCashPhone" value="<%= shamCashPhone || '' %>" dir="ltr">
          </div>
          <div class="col-12 mt-4">
            <h6 class="text-primary"><i class="bi bi-whatsapp"></i> <%= __('whatsapp_settings') %></h6>
          </div>
          <div class="col-md-6">
            <label class="form-label"><%= __('whatsapp_phone') %></label>
            <input type="text" class="form-control" name="whatsappPhone" value="<%= whatsappPhone || '' %>" dir="ltr">
            <small class="text-muted"><%= __('whatsapp_phone_desc') %></small>
          </div>
          <div class="col-12">
            <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> <%= __('save') %></button>
          </div>
        </form>
      </div>
    </div>
  </section>
</main>

<%- include('../partials/scripts') %>
</body>
</html>
