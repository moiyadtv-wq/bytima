<%- include('partials/header') %>
<main class="d-flex flex-nowrap">
  <%- include('partials/sidebar', { currentPage: '' }) %>
  <div class="b-example-divider b-example-vr"></div>

  <section class="flex-grow-1 p-4">
    <%- include('partials/navbar') %>

    <div class="card shadow mt-4">
      <div class="card-header"><h5 class="mb-0"><i class="bi bi-funnel me-2"></i><%= __('advanced_search') %></h5></div>
      <div class="card-body">
        <form class="row g-2" action="/customers/search" method="GET">
          <div class="col-md-3">
            <input type="text" class="form-control" name="q" placeholder="<%= __('full_name') %>..." value="<%= searchTerm || '' %>">
          </div>
          <div class="col-md-2">
            <select class="form-select" name="country">
              <option value=""><%= __('all_countries') %></option>
              <option <%= country === 'Morocco' ? 'selected' : '' %>>Morocco</option>
              <option <%= country === 'Egypt' ? 'selected' : '' %>>Egypt</option>
              <option <%= country === 'Palestine' ? 'selected' : '' %>>Palestine</option>
              <option <%= country === 'Jordan' ? 'selected' : '' %>>Jordan</option>
            </select>
          </div>
          <div class="col-md-2">
            <select class="form-select" name="gender">
              <option value=""><%= __('all_genders') %></option>
              <option <%= gender === 'Male' ? 'selected' : '' %>><%= __('male') %></option>
              <option <%= gender === 'Female' ? 'selected' : '' %>><%= __('female') %></option>
            </select>
          </div>
          <div class="col-md-2">
            <input type="number" class="form-control" name="minAge" placeholder="<%= __('min_age') || 'Min age' %>" value="<%= minAge || '' %>">
          </div>
          <div class="col-md-2">
            <input type="number" class="form-control" name="maxAge" placeholder="<%= __('max_age') || 'Max age' %>" value="<%= maxAge || '' %>">
          </div>
          <div class="col-md-1">
            <button type="submit" class="btn btn-primary w-100"><i class="bi bi-search"></i></button>
          </div>
        </form>
      </div>
    </div>

    <div class="card shadow mt-4">
      <div class="card-header"><h5 class="mb-0"><%= __('results') %> (<%= results ? results.length : 0 %>)</h5></div>
      <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0 align-middle">
          <thead><tr>
            <th>#</th>
            <th><%= __('image') %></th>
            <th><%= __('full_name') %></th>
            <th><%= __('gender') %></th>
            <th><%= __('country') %></th>
            <th><%= __('age') %></th>
            <th><%= __('action') %></th>
          </tr></thead>
          <tbody>
            <% if (results && results.length > 0) { %>
              <% results.forEach((p, i) => { %>
                <tr>
                  <th><%= i + 1 %></th>
                  <td>
                    <% if (p.image) { %>
                      <img src="<%= p.image %>" class="img-thumb" alt="">
                    <% } else { %>
                      <span class="text-muted">—</span>
                    <% } %>
                  </td>
                  <td><%= p.name %></td>
                  <td><%= p.gender === 'Male' ? __('male') : __('female') %></td>
                  <td><%= p.country %></td>
                  <td><%= p.age %></td>
                  <td>
                    <a data-bs-toggle="tooltip" data-bs-title="<%= __('view') %>" class="btn btn-primary btn-sm" href="/customers/view/<%= p._id %>"><i class="bi bi-eye"></i></a>
                    <a data-bs-toggle="tooltip" data-bs-title="<%= __('edit') %>" class="btn btn-warning btn-sm" href="/customers/edit/<%= p._id %>"><i class="bi bi-pencil"></i></a>
                    <button data-bs-toggle="tooltip" data-bs-title="<%= __('delete') %>" class="btn btn-danger btn-sm" onclick="deleteUser('<%= p._id %>')"><i class="bi bi-trash"></i></button>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="7" class="text-center py-4 text-muted"><%= __('no_results') %></td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </section>
</main>

<%- include('partials/scripts') %>
<script>
  async function deleteUser(id) {
    if (!confirm('<%= __('confirm_delete') %>')) return;
    const res = await fetch('/customers/delete/' + id, { method: 'POST' });
    if (res.ok) location.href = '/';
    else alert('<%= __('error_occurred') %>');
  }
</script>
</body>
</html>
